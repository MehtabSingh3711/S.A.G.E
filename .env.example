# ══════════════════════════════════════════════════════════════════
#  🦉 SAGE — Environment Variables
# ══════════════════════════════════════════════════════════════════
#
#  Copy this file to sage/.env and fill in your values:
#    cp .env.example sage/.env
#
# ──────────────────────────────────────────────────────────────────

# Ollama base URL (default: http://localhost:11434)
# Ensure Ollama is running: ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# NotebookLM Notebook ID
# Find this in your NotebookLM URL: https://notebooklm.google.com/notebook/<THIS_ID>
# Authenticate first: notebooklm login
NOTEBOOKLM_NOTEBOOK_ID=your_notebook_id_here

# Obsidian vault path (absolute path recommended)
# This is where SAGE will write your generated study notes
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
